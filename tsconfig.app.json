{
	"extends": "./.nuxt/tsconfig.json",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@/*": ["./app/*"],
			"~/database/*": ["./database/*"],
			"~/types/*": ["./types/*"]
		},
		"strict": true,
		"exactOptionalPropertyTypes": true,
		"noImplicitAny": true,
		"noImplicitOverride": true,
		"noImplicitReturns": true,
		"noImplicitThis": true,
		"noPropertyAccessFromIndexSignature": true,
		"noUncheckedIndexedAccess": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true
	},
	"include": [
		"app/**/*",
		"database/**/*",
		"types/**/*",
		"composables/**/*",
		"utils/**/*"
	],
	"exclude": [
		"node_modules",
		".nuxt",
		"dist",
		"src-tauri/target"
	]
}
