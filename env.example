# Configuración de la aplicación
NODE_ENV=development
DATABASE_URL=sqlite:./database/pos.db
ENCRYPTION_KEY=your-encryption-key-here

# APIs externas
BCV_API_URL=https://api.bcv.org.ve
DOLAR_TODAY_API_URL=https://s3.amazonaws.com/dolartoday

# Configuración de la aplicación
API_BASE_URL=http://localhost:3000/api
APP_NAME=POS Venezuela
APP_VERSION=1.0.0

# Configuración de monedas
DEFAULT_CURRENCY=BS
SUPPORTED_CURRENCIES=BS,USD,EUR

# Configuración de impuestos (Venezuela)
IVA_RATE=0.16
ISLR_RATE=0.02

# Configuración de sincronización
SYNC_INTERVAL=15
AUTO_SYNC=true

# Configuración de backup
BACKUP_INTERVAL=24
AUTO_BACKUP=true
