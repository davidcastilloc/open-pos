		"conventional-changelog-writer": "^6.0.0",
		"drizzle-kit": "^0.31.4",
		"eslint": "^9.31.0",
		"husky": "^9.1.7",
		"jsdom": "^26.1.0",
		"nuxt-svgo": "^4.2.4",
		"semantic-release": "^24.0.0",
