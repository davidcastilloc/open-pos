You are an expert in Nuxt 4, Tauri, TypeScript, Zod, Drizzle ORM, Tailwind CSS.

globs:
  - app/**/*.vue
  - app/composables/**/*.ts
  - app/components/**/*.vue
  - app/pages/**/*.vue
  - app/database/**/*.ts
alwaysApply: false

rules:

  - id: script-setup-lang-ts
    level: error
    message: "Todos los SFC deben usar `<script setup lang=\"ts\">`."
    appliesTo: "app/**/*.vue"
    pattern: (?s)"<script(?:(?!setup).)*>"
    mustMatch: (?s)"<script[^>]*setup[^>]*lang=(?:\"|')ts(?:\"|')"

  - id: ban-options-api
    level: error
    message: "Prohibido Options API (`export default { ... }`). Usa Composition API con `<script setup>`."
    appliesTo: "app/**/*.vue"
    pattern: "export\\s+default\\s*\\{"

  - id: enforce-pascalcase-filenames
    level: error
    message: "Los archivos de componentes deben usar PascalCase (Ej: MyComponent.vue)."
    appliesTo: "app/components/**/*.vue, app/pages/**/*.vue"
    fileNamePattern: "^[A-Z][A-Za-z0-9]+\\.vue$"

  - id: composables-location-name
    level: error
    message: "Los composables deben estar en `app/composables/` y llamarse `useX`."
    appliesTo: "app/composables/**/*.ts"
    pattern: "export\\s+function\\s+(?!use)[A-Za-z0-9_]+\\s*\\("

  - id: defineprops-definemits-typed
    level: error
    message: "Definir props y emits con tipado explícito (`defineProps<T>()`, `defineEmits<T>()`)."
    appliesTo: "app/**/*.vue"
    pattern: "defineProps\\s*\\(|defineEmits\\s*\\("
    negativePattern: "defineProps\\s*\\(\\s*\\)|defineEmits\\s*\\(\\s*\\)"

  - id: avoid-any
    level: error
    message: "Prohibido usar `any`. Usa tipos concretos o `unknown`."
    appliesTo: "app/**/*.vue, app/**/*.ts"
    pattern: "(:|as)\\s*any\\b"

  - id: enforce-zod-validation
    level: error
    message: "Formularios/entradas externas deben validarse con Zod (`z.object(...)`)."
    appliesTo: "app/**/*.vue"
    pattern: "(v-model|@submit|@submit.prevent|onSubmit|handleSubmit)"
    negativePattern: "from\\s+['\"]zod['\"]|z\\.object\\("

  - id: drizzle-schema-usage
    level: error
    message: "Las consultas deben usar los schemas de Drizzle. Prohibido SQL sin tipado."
    appliesTo: "app/database/**/*.ts"
    pattern: "(sql`|queryRaw|executeRaw)"

  - id: tauri-apis-encapsulate
    level: error
    message: "No importar `@tauri-apps/*` en componentes. Encapsular en `app/composables/tauri/useX.ts`."
    appliesTo: "app/**/*.vue"
    pattern: "from\\s+['\"]@tauri-apps/[^'\"]+['\"]"

  - id: nuxt-auto-imports
    level: error
    message: "Usa auto-imports de Nuxt. No importar `ref`, `reactive`, `useState`, `useRouter`, etc."
    appliesTo: "app/**/*.vue"
    pattern: "import\\s+\\{[^}]*\\b(ref|reactive|useState|useRouter|useFetch)\\b[^}]*\\}\\s+from\\s+['\"](vue|nuxt)['\"]"

  - id: prefer-useFetch-in-pages
    level: error
    message: "En páginas/componentes usar `useFetch({ server: false })`. `$fetch` solo en handlers del cliente."
    appliesTo: "app/pages/**, app/components/**"
    pattern: "\\$fetch\\s*\\("

  - id: useAsyncData-options-recommendation
    level: error
    message: "Cuando uses `useAsyncData`, debes incluir `lazy: true` y `server: false`."
    appliesTo: "app/**/*.vue"
    pattern: "useAsyncData\\s*\\("
    negativePattern: "lazy\\s*:\\s*true|server\\s*:\\s*false"

  - id: prefer-nuxtimage-nuxtpicture
    level: error
    message: "Usa `<NuxtImage>` o `<NuxtPicture>` para optimización de imágenes."
    appliesTo: "app/**/*.vue"
    pattern: "<img\\b"
    negativePattern: "<NuxtImage|<NuxtPicture"

  - id: color-rules-tailwind
    level: error
    message: "Prohibido usar clases de Tailwind para color de texto (`text-…`) o fondo (`bg-…`) en componentes. Usa tokens/variables de estilo definidos en la UI/tailwind config."
    appliesTo: "app/**/*.vue"
    pattern: "class\\s*=\\s*['\"][^'\"]*(?:\\btext-[^\\s'\"\\]]+|\\bbg-[^\\s'\"\\]]+)[^'\"]*['\"]"

